<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ur.Gui.ViewModels"
        x:Class="Ur.Gui.Views.ApiKeyDialog"
        Title="API Key"
        Width="420" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:ApiKeyDialogViewModel />
    </Design.DataContext>

    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Enter your OpenRouter API key:" />

        <TextBox Text="{Binding ApiKey}"
                 PasswordChar="*"
                 Watermark="sk-or-…">
            <TextBox.KeyBindings>
                <KeyBinding Gesture="Return" Command="{Binding SubmitCommand}" />
            </TextBox.KeyBindings>
        </TextBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="OnCancel" />
            <Button Content="OK" Command="{Binding SubmitCommand}" Click="OnSubmit"
                    IsDefault="True" />
        </StackPanel>
    </StackPanel>

</Window>
