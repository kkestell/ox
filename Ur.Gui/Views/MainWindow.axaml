<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ur.Gui.ViewModels"
        xmlns:views="using:Ur.Gui.Views"
        x:Class="Ur.Gui.Views.MainWindow"
        Title="Ur"
        Width="900" Height="650"
        MinWidth="480" MinHeight="300">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0" BorderBrush="#333">
            <TextBlock Text="{Binding SelectedModelId}"
                       Margin="8,4"
                       FontSize="11"
                       Foreground="Gray" />
        </Border>

        <Grid>
            <TextBlock Text="Starting…"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsLoading}" />

            <ContentControl Content="{Binding ActiveSession}"
                            IsVisible="{Binding ActiveSession, Converter={x:Static ObjectConverters.IsNotNull}}">
                <ContentControl.ContentTemplate>
                    <DataTemplate DataType="vm:SessionViewModel">
                        <views:SessionView />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
        </Grid>
    </DockPanel>

</Window>
