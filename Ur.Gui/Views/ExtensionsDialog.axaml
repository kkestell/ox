<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ur.Gui.ViewModels"
        xmlns:ur="using:Ur"
        x:Class="Ur.Gui.Views.ExtensionsDialog"
        Title="Extensions"
        Width="680" Height="480"
        CanResize="True"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    Spacing="8" Margin="0,12,0,0">
            <Button Content="Reset to Default" Command="{Binding ResetCommand}" />
            <Button Content="Close" Click="OnClose" HorizontalAlignment="Right" />
        </StackPanel>

        <ListBox ItemsSource="{Binding Extensions}"
                 SelectedItem="{Binding SelectedExtension}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="ur:UrExtensionInfo">
                    <Grid ColumnDefinitions="60,*,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Tier}"
                                   Foreground="Gray"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}" Foreground="Gray"
                                       FontSize="11" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding Version}"
                                   Foreground="Gray" Margin="12,0"
                                   VerticalAlignment="Center" />
                        <CheckBox Grid.Column="3"
                                  IsChecked="{Binding DesiredEnabled, Mode=OneWay}"
                                  Click="OnToggleChecked"
                                  VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>

</Window>
