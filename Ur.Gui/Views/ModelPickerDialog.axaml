<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ur.Gui.ViewModels"
        xmlns:providers="using:Ur.Providers"
        x:Class="Ur.Gui.Views.ModelPickerDialog"
        Title="Select Model"
        Width="600" Height="500"
        CanResize="True"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:ModelPickerDialogViewModel>
            <x:Arguments>
                <x:Array Type="providers:ModelInfo" />
            </x:Arguments>
        </vm:ModelPickerDialogViewModel>
    </Design.DataContext>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Cancel" Click="OnCancel" />
            <Button Content="Select" Command="{Binding SelectCommand}" Click="OnSelect"
                    IsDefault="True" />
        </StackPanel>

        <DockPanel>
            <TextBox DockPanel.Dock="Top"
                     Text="{Binding FilterText}"
                     Watermark="Filter models…"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,8" />

            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,80,80,80" Margin="12,0,12,4">
                <TextBlock Grid.Column="0" Text="Model" Foreground="Gray" FontSize="11" />
                <TextBlock Grid.Column="1" Text="Context" Foreground="Gray" FontSize="11" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="2" Text="In/M" Foreground="Gray" FontSize="11" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="3" Text="Out/M" Foreground="Gray" FontSize="11" HorizontalAlignment="Right" />
            </Grid>

            <ListBox ItemsSource="{Binding FilteredModels}"
                     SelectedItem="{Binding SelectedModel}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="providers:ModelInfo">
                        <Grid ColumnDefinitions="*,80,80,80">
                            <TextBlock Grid.Column="0" Text="{Binding Id}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding ContextLength, StringFormat='{}{0:N0}'}"
                                       Foreground="Gray" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding InputCostPerMToken, StringFormat='${0:F2}'}"
                                       Foreground="Gray" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding OutputCostPerMToken, StringFormat='${0:F2}'}"
                                       Foreground="Gray" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </DockPanel>

</Window>
