<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ur.Gui.ViewModels"
             x:Class="Ur.Gui.Views.SessionView">

    <UserControl.Resources>
        <!-- User message -->
        <DataTemplate x:Key="UserMessageTemplate" DataType="vm:UserMessageViewModel">
            <Border Margin="4,2" Padding="8,4"
                    Background="#1A4466" CornerRadius="4"
                    HorizontalAlignment="Right" MaxWidth="600">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
            </Border>
        </DataTemplate>

        <!-- Assistant message -->
        <DataTemplate x:Key="AssistantMessageTemplate" DataType="vm:AssistantMessageViewModel">
            <Border Margin="4,2" Padding="8,4"
                    Background="#1A1A1A" CornerRadius="4"
                    HorizontalAlignment="Left" MaxWidth="700">
                <StackPanel>
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                    <TextBlock Text="…" IsVisible="{Binding IsStreaming}"
                               Foreground="Gray" FontSize="10" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Tool message -->
        <DataTemplate x:Key="ToolMessageTemplate" DataType="vm:ToolMessageViewModel">
            <Border Margin="4,2" Padding="6,3"
                    Background="#0D2A0D" CornerRadius="4"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="⚙" Foreground="Green" />
                    <TextBlock Text="{Binding ToolName}" Foreground="LightGreen" />
                    <TextBlock Text="{Binding Result}" Foreground="Gray"
                               IsVisible="{Binding IsComplete}" TextWrapping="Wrap" MaxWidth="500" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- System message -->
        <DataTemplate x:Key="SystemMessageTemplate" DataType="vm:SystemMessageViewModel">
            <Border Margin="4,2" Padding="6,3"
                    HorizontalAlignment="Center">
                <TextBlock Text="{Binding Text}" Foreground="OrangeRed"
                           TextWrapping="Wrap" FontSize="11" />
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <!-- Input area -->
        <DockPanel DockPanel.Dock="Bottom" Margin="8">
            <Button DockPanel.Dock="Right" Margin="6,0,0,0"
                    Content="Send"
                    Command="{Binding SendCommand}"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Center"
                    Padding="12,0" />

            <TextBox Text="{Binding InputText}"
                     Watermark="Message…"
                     AcceptsReturn="False"
                     VerticalContentAlignment="Center"
                     IsEnabled="{Binding !IsTurnRunning}">
                <TextBox.KeyBindings>
                    <KeyBinding Gesture="Return" Command="{Binding SendCommand}" />
                </TextBox.KeyBindings>
            </TextBox>
        </DockPanel>

        <!-- Message list -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}">
                            <ContentControl.DataTemplates>
                                <DataTemplate DataType="vm:UserMessageViewModel">
                                    <Border Margin="4,2" Padding="8,4"
                                            Background="#1A4466" CornerRadius="4"
                                            HorizontalAlignment="Right" MaxWidth="600">
                                        <SelectableTextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                                <DataTemplate DataType="vm:AssistantMessageViewModel">
                                    <Border Margin="4,2" Padding="8,4"
                                            Background="#1A1A1A" CornerRadius="4"
                                            HorizontalAlignment="Left" MaxWidth="700">
                                        <StackPanel>
                                            <SelectableTextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                            <TextBlock Text="…" IsVisible="{Binding IsStreaming}"
                                                       Foreground="Gray" FontSize="10" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                                <DataTemplate DataType="vm:ToolMessageViewModel">
                                    <Border Margin="4,2" Padding="6,3"
                                            Background="#0D2A0D" CornerRadius="4"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="⚙" Foreground="Green" />
                                            <SelectableTextBlock Text="{Binding ToolName}" Foreground="LightGreen" />
                                            <SelectableTextBlock Text="{Binding Result}" Foreground="Gray"
                                                       IsVisible="{Binding IsComplete}"
                                                       TextWrapping="Wrap" MaxWidth="500" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                                <DataTemplate DataType="vm:SystemMessageViewModel">
                                    <Border Margin="4,2" Padding="6,3"
                                            HorizontalAlignment="Center">
                                        <SelectableTextBlock Text="{Binding Text}" Foreground="OrangeRed"
                                                   TextWrapping="Wrap" FontSize="11" />
                                    </Border>
                                </DataTemplate>
                            </ContentControl.DataTemplates>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</UserControl>
