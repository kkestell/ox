{
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(dotnet test:*)",
      "Bash(dotnet build:*)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(find:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-hook.sh"
          }
        ]
      }
    ]
  }
}
